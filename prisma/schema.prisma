

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String?
  location      String?
  headline      String?
  bio           String?
  skills        String[]  @default([])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  applications  Application[]
  cvAnalysis    CVAnalysis[]
}

model Application {
  id            String    @id @default(cuid())
  userId        String
  company       String
  position      String
  status        String    @default("applied") // applied, interview, rejected, offer
  dateApplied   DateTime  @default(now())
  location      String?
  salary        String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model CVAnalysis {
  id            String    @id @default(cuid())
  userId        String
  fileName      String
  atsScore      Int?
  strengths     String[]  @default([])
  weaknesses    String[]  @default([])
  missingSkills String[]  @default([])
  suggestions   String[]  @default([])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}